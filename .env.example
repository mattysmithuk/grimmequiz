# Password for the /admin leaderboard. Change before the show.
ADMIN_PASSWORD=grimme-red-2026

# Firebase project from the web app configuration.
FIREBASE_PROJECT_ID=grimmequiz

# Local development: download a service-account key in Firebase Console under
